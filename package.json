        "@types/ws": "^8.18.1",
        "boxen": "^7.1.1",
        "bun-types": "latest",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "conf": "^15.1.0",
        "inquirer": "^9.2.14",
        "ora": "^8.0.1",
        "tsup": "^8.0.2",
