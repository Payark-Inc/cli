{
    "name": "@payark/cli",
    "version": "0.1.2",
    "description": "The official command-line interface for PayArk.",
    "bin": {
        "payark": "dist/index.js"
    },
    "files": [
        "dist"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Payark-Inc/payark.git",
        "directory": "packages/cli"
    },
